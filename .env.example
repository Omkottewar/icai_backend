# ICAI Nagpur — example env. Copy to .env and fill in.
# Never commit the real .env (it is gitignored).

# Database (Supabase Postgres direct connection for migrations)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
# JWT signing secret. Must be at least 32 characters. Rotating this
# invalidates every outstanding login cookie (acts as a global sign-out).
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Auth0
# For embedded login (no redirect), enable in the Auth0 dashboard:
#   Application → Settings → Advanced → Grant Types → enable "Password"
#   Tenant → Settings → API Authorization Settings → Default Directory =
#     <your DB connection name, same value as AUTH0_CONNECTION below>
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:4000/api/auth/callback
# Name of the Auth0 DB connection used for email/password sign-in & signup.
# Defaults to Auth0's out-of-the-box "Username-Password-Authentication".
AUTH0_CONNECTION=Username-Password-Authentication

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ICAI Nagpur <no-reply@nagpur.icai.org>"

# ICAI directory SSO (MRN / SRN)
ICAI_SSO_BASE_URL=
ICAI_SSO_CLIENT_ID=
ICAI_SSO_CLIENT_SECRET=

# Object storage
STORAGE_BUCKET=icai-nagpur

# Pragyaan / RAG
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
