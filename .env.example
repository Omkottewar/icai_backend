# ICAI Nagpur — example env. Copy to .env and fill in.
# Never commit the real .env (it is gitignored).

# Database (Supabase Postgres direct connection for migrations)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
# JWT signing secret. Must be at least 32 characters. Rotating this
# invalidates every outstanding login cookie (acts as a global sign-out).
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Auth0
# For embedded login (no redirect), enable in the Auth0 dashboard:
#   Application → Settings → Advanced → Grant Types → enable "Password"
#   Tenant → Settings → API Authorization Settings → Default Directory =
#     <your DB connection name, same value as AUTH0_CONNECTION below>
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:4000/api/auth/callback
# Name of the Auth0 DB connection used for email/password sign-in & signup.
# Defaults to Auth0's out-of-the-box "Username-Password-Authentication".
AUTH0_CONNECTION=Username-Password-Authentication

# Payments — the branch is currently on the UPI QR + manual verification
# flow (see backend/server/routes/registrations.ts). Admin sets the UPI VPA
# and payee display name from Site Content admin (payment_upi_id /
# payment_upi_payee_name in site_settings); no env vars needed here.
#
# The old Razorpay integration was removed in the 0084 migration series.
# To re-enable: restore lib/razorpay.ts + swap /register back, and add
# RAZORPAY_KEY_ID / RAZORPAY_KEY_SECRET / RAZORPAY_WEBHOOK_SECRET here.

# Email (Resend) — https://resend.com
#   1. Sign up at https://resend.com (free tier = 3,000 emails/month, 100/day)
#   2. Add and verify your sending domain (Domains → Add Domain). Resend will
#      show 4 DNS records (DKIM TXT, SPF MX + TXT, optional DMARC TXT) —
#      paste them into your DNS provider, wait ~15 min, click Verify.
#   3. API Keys → Create API Key → "Sending access" → copy into RESEND_API_KEY.
#   4. EMAIL_FROM must use the verified domain.
#
# This same Resend account also powers Auth0's transactional emails (signup
# verification, password reset) — configured in Auth0 → Branding → Email
# Provider → Resend. One API key is fine for both.
RESEND_API_KEY=
EMAIL_FROM="ICAI Nagpur <no-reply@icainagpur.in>"
# Plain-address used in the transactional email footer ("Sent from …").
# Falls back to no-reply@icainagpur.in if unset. Override only if your
# verified sender differs from the default.
EMAIL_FROM_ADDR=no-reply@icainagpur.in
# Public URL of the branch logo used in the email envelope header. The
# image must be publicly reachable (Resend pulls it when the recipient
# opens the email). Default points to the copy uploaded via
# `npx tsx scripts/upload-email-logo.mjs` — override to A/B test a
# different logo without redeploying.
EMAIL_LOGO_URL=
# reCAPTCHA v3 — server-side verification of the token submitted by the
# Contact / Grievance form. Free at https://www.google.com/recaptcha/admin
# (pick v3, add your domains, copy site key into frontend .env, secret here).
# Leave empty in dev — the verifier silently passes when unset.
RECAPTCHA_SECRET_KEY=
RECAPTCHA_MIN_SCORE=0.5

# ICAI directory SSO (MRN / SRN)
ICAI_SSO_BASE_URL=
ICAI_SSO_CLIENT_ID=
ICAI_SSO_CLIENT_SECRET=

# Object storage — Supabase Storage driver auto-engages when SUPABASE_URL
# + SUPABASE_SERVICE_ROLE_KEY are set (see backend/server/lib/storage.ts).
# Without those, files write to ./uploads on local disk.
#
# Setup steps (one-time):
#   1. In your Supabase project: Storage → Create bucket → name it (e.g.
#      "icai-nagpur-uploads") and toggle "Public bucket" ON.
#   2. Set SUPABASE_BUCKET below to that name.
#   3. Make sure SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are filled in
#      (they're in the Database section above — same values as Postgres).
#   4. To copy existing local uploads into the bucket, run:
#        npm run storage:migrate:dry   # preview
#        npm run storage:migrate       # actually copy
SUPABASE_BUCKET=icai-nagpur-uploads
STORAGE_BUCKET=icai-nagpur

# Pragyaan / RAG
# Blank OPENAI_API_KEY ⇒ dev-echo mode (deterministic offline stand-in,
# no API spend). Set a real key to enable live embeddings + streamed chat.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini                    # fast budget model default; override if quality regresses
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # canonical name (legacy EMBEDDING_MODEL still honoured)
EMBEDDING_MODEL=text-embedding-3-small          # legacy alias for OPENAI_EMBEDDING_MODEL
EMBEDDING_DIMENSIONS=1536                        # must match kb_chunks vector(1536)
PRAGYAAN_TOP_K=6                                 # ANN search fan-out (chunks per query)
PRAGYAAN_MIN_SIMILARITY=0.18                     # cosine similarity floor; below ⇒ no-answer
PRAGYAAN_MAX_CONTEXT_CHARS=12000                 # cap on assembled context handed to the model
PRAGYAAN_ANON_RATE_PER_MIN=8                     # /chat rate limit for anonymous (by-IP) callers
PRAGYAAN_USER_RATE_PER_MIN=30                    # /chat rate limit for authenticated callers
PRAGYAAN_RERANK=0                                # LLM reranker (off by default; adds ~250ms for marginal quality)

# Sentry (error tracking) — https://sentry.io
#   1. Create a project (platform = Node.js Express).
#   2. Copy the DSN from Project Settings → Client Keys (DSN) into SENTRY_DSN.
#   3. Leave blank in dev — the SDK no-ops when DSN is unset AND is
#      additionally gated on NODE_ENV=production (see server/instrument.ts).
#      Flip SENTRY_ENABLE_IN_DEV=1 for one-off local integration tests.
#   4. SENTRY_TRACES_SAMPLE_RATE: 0.0–1.0 share of requests sent as perf
#      traces (0.1 = 10%). Free tier is 10k traces/mo; keep this low.
#   5. SENTRY_RELEASE (optional): release identifier for source-map upload
#      and regression tracking — set to the git SHA in your deploy pipeline.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_ENABLE_IN_DEV=
SENTRY_RELEASE=

# Web Push (PWA notifications) — VAPID keypair
# Generate once per environment:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The PUBLIC key is also exposed to the browser via /api/push/public-key.
# VAPID_SUBJECT must be a mailto: or https: URL identifying the app to push services.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@nagpur.icai.org
