# ICAI Nagpur — example env. Copy to .env and fill in.
# Never commit the real .env (it is gitignored).

# Database (Supabase Postgres direct connection for migrations)
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
SUPABASE_PROJECT_REF=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Server
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:5173
API_URL=http://localhost:4000
# JWT signing secret. Must be at least 32 characters. Rotating this
# invalidates every outstanding login cookie (acts as a global sign-out).
JWT_SECRET=replace-me-with-a-long-random-string-at-least-32-chars

# Auth0
# For embedded login (no redirect), enable in the Auth0 dashboard:
#   Application → Settings → Advanced → Grant Types → enable "Password"
#   Tenant → Settings → API Authorization Settings → Default Directory =
#     <your DB connection name, same value as AUTH0_CONNECTION below>
AUTH0_DOMAIN=
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
AUTH0_AUDIENCE=
AUTH0_CALLBACK_URL=http://localhost:4000/api/auth/callback
# Name of the Auth0 DB connection used for email/password sign-in & signup.
# Defaults to Auth0's out-of-the-box "Username-Password-Authentication".
AUTH0_CONNECTION=Username-Password-Authentication

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="ICAI Nagpur <no-reply@nagpur.icai.org>"
# Dev safety net — when set AND NODE_ENV != production, every outbound
# email is redirected to this address (with the original recipient
# prepended to the subject). Keeps test grievances / registrations /
# escalations from accidentally hitting real branch addresses while SMTP
# is being wired up. Leave blank in production.
DEV_EMAIL_OVERRIDE=

# ICAI directory SSO (MRN / SRN)
ICAI_SSO_BASE_URL=
ICAI_SSO_CLIENT_ID=
ICAI_SSO_CLIENT_SECRET=

# Object storage
STORAGE_BUCKET=icai-nagpur

# Pragyaan / RAG
# Blank OPENAI_API_KEY ⇒ dev-echo mode (deterministic offline stand-in,
# no API spend). Set a real key to enable live embeddings + streamed chat.
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=                              # latest BUDGET model (GPT-5.x mini/nano tier) — set before launch
OPENAI_EMBEDDING_MODEL=text-embedding-3-small   # canonical name (legacy EMBEDDING_MODEL still honoured)
EMBEDDING_MODEL=text-embedding-3-small          # legacy alias for OPENAI_EMBEDDING_MODEL
EMBEDDING_DIMENSIONS=1536                        # must match kb_chunks vector(1536)
PRAGYAAN_TOP_K=6                                 # ANN search fan-out (chunks per query)
PRAGYAAN_MIN_SIMILARITY=0.18                     # cosine similarity floor; below ⇒ no-answer
PRAGYAAN_MAX_CONTEXT_CHARS=12000                 # cap on assembled context handed to the model
PRAGYAAN_ANON_RATE_PER_MIN=8                     # /chat rate limit for anonymous (by-IP) callers
PRAGYAAN_USER_RATE_PER_MIN=30                    # /chat rate limit for authenticated callers

# Web Push (PWA notifications) — VAPID keypair
# Generate once per environment:
#   node -e "console.log(require('web-push').generateVAPIDKeys())"
# The PUBLIC key is also exposed to the browser via /api/push/public-key.
# VAPID_SUBJECT must be a mailto: or https: URL identifying the app to push services.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:no-reply@nagpur.icai.org
