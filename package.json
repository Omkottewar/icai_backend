    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.2",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^6.9.16",
    "postgres": "^3.4.5",
    "sharp": "^0.35.1",
    "web-push": "^3.6.7",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/archiver": "^8.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
