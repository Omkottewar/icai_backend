  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/index.ts",
    "start": "tsx server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "node scripts/run-migrations.mjs",
