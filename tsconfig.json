{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "types": ["node"]
  },
  "include": ["server/**/*.ts", "db/**/*.ts", "schema/**/*.ts", "lib/**/*.ts", "drizzle.config.ts"]
}
